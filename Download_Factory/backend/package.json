{
  "name": "download-factory-backend",
  "version": "1.0.0",
  "description": "Instagram & Facebook Media Downloader - Backend API + Queue Worker",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node queue/worker.js",
    "dev:worker": "nodemon queue/worker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bullmq": "^5.12.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
